# GraalVM Native Image + Distroless
# Imagem final: ~50MB, startup < 100ms

# Stage 1: Native compile
FROM ghcr.io/graalvm/native-image:25 AS builder
WORKDIR /app
COPY . .
RUN ./mvnw -Pnative native:compile -DskipTests

# Stage 2: Distroless runtime (sem shell, sem gerenciador de pacotes)
FROM gcr.io/distroless/base-nossl-debian12
WORKDIR /app
COPY --from=builder /app/target/app .

EXPOSE 8080
ENTRYPOINT ["/app/app"]
